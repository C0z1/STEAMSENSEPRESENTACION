# ════════════════════════════════════════════════════════
#  SteamSense — Variables de entorno
#  Copia este archivo como .env y rellena los valores.
#  NUNCA subas .env a GitHub.
# ════════════════════════════════════════════════════════

# ── APIs ─────────────────────────────────────────────────
STEAM_API_KEY=your_steam_api_key_here
ITAD_API_KEY=your_itad_api_key_here

# ── Seguridad ─────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=your_random_secret_here

# ── URLs (crítico para Steam OAuth) ───────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── DuckDB ────────────────────────────────────────────────
DUCKDB_PATH=./data/steamsense.duckdb
DUCKDB_MEMORY_LIMIT=512MB
DUCKDB_THREADS=2

# ── Comportamiento ────────────────────────────────────────
ENV=development
TOP_N_GAMES=200
REQUEST_BATCH_SIZE=10
REQUEST_DELAY=0.5
ITAD_COUNTRY=US
ITAD_HISTORY_SINCE=2022-01-01T00:00:00Z
